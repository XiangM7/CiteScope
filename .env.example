# Shared example configuration for local development.
# Copy backend-related values to `backend/.env`.
# Copy frontend-related values to `frontend/.env.local`.

# Backend
DATABASE_URL=sqlite:///./backend/data/citescope.db
UPLOADS_DIR=./backend/data/uploads
CHROMA_DIR=./backend/data/chroma
CORS_ORIGINS=http://localhost:3000
CHUNK_SIZE_CHARS=900
CHUNK_OVERLAP_CHARS=150
RETRIEVAL_TOP_K=5
REQUEST_TIMEOUT_SECONDS=45
HASHING_DIMENSIONS=1024

# Answer provider
LLM_PROVIDER=local
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=

# Embedding provider
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
